ErrorDocument 404 /404.html

RewriteEngine On

RewriteCond %{THE_REQUEST} \s/+(index\.html)[\s?] [NC]
RewriteRule ^index\.html$ / [R=301,L]


RewriteEngine On
Redirect 301 /gratis-produkt-probe.html  https://www.fitonline.de/

RewriteEngine On
Redirect 301 /produkte-kritik.html  https://www.fitonline.de/kritik-faq.html

RewriteEngine On
Redirect 301 /produkte-qualitaet.html  https://www.fitonline.de/nahrungsergaenzungsmittel-fit-qualitaet.html


<IfModule mod_headers.c>
    # Aktiviert HSTS für ein Jahr (31536000 Sekunden)
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
</IfModule>


<IfModule mod_expires.c>

  ExpiresActive On
  
  # Bilder für 1 Jahr cachen
  ExpiresByType image/jpg "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  
  # CSS und JS für 1 Monat
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  
  # MIME-Typen für WOFF2 sicherstellen
  AddType font/woff2 .woff2

  # Cache-Dauer für Schriftarten 1 Monat
  ExpiresByType font/woff2 "access plus 1 month"
  ExpiresByType application/font-woff2 "access plus 1 month"
  ExpiresByType application/x-font-woff2 "access plus 1 month"

</IfModule>
